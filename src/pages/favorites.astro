---
import Layout from '../layouts/Layout.astro';
import FavoritesExplorer from '../components/FavoritesExplorer';
import { getAllStations } from '../server/db';
import { getModelCategoriesFromStations } from '../utils/stations';
import { Heart } from 'lucide-react';

const stations = getAllStations();
const modelCategories = getModelCategoriesFromStations(stations);
---

<Layout title="我的收藏 — AI Hub" description="收藏的 AI API 中转站列表。">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-rose-500/20 to-pink-500/20 border border-rose-500/20 flex items-center justify-center">
        <Heart className="w-5 h-5 text-rose-400" />
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-100">我的收藏</h1>
        <p class="text-sm text-slate-500">你收藏的中转站，数据保存在浏览器本地</p>
      </div>
    </div>

    <FavoritesExplorer client:load stations={stations} modelCategories={modelCategories} />
  </div>
</Layout>
