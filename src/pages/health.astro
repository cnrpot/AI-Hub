---
import Layout from '../layouts/Layout.astro';
import HealthDashboard from '../components/HealthDashboard';
import { getAllStations } from '../server/db';
import { Activity } from 'lucide-react';

const stations = getAllStations();
---

<Layout title="健康监控 — AI Hub" description="实时检测各 AI API 中转站的可用性和响应速度。">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500/20 to-blue-500/20 border border-green-500/20 flex items-center justify-center">
        <Activity className="w-5 h-5 text-green-400" />
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-100">健康监控</h1>
        <p class="text-sm text-slate-500">实时检测各中转站的可用性和响应速度</p>
      </div>
    </div>

    <HealthDashboard client:load stations={stations} />
  </div>
</Layout>
