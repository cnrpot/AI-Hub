---
import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft, Save } from 'lucide-react';
---

<Layout title="新增中转站 — AI Hub">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
      <a href="/admin" class="hover:text-slate-300 transition-colors">管理面板</a>
      <span>/</span>
      <span class="text-slate-300">新增中转站</span>
    </nav>

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-slate-100">新增中转站</h1>
      <a href="/admin" class="btn-ghost">
        <ArrowLeft className="w-4 h-4" />
        返回
      </a>
    </div>

    <!-- Form -->
    <form id="station-form" class="card-base space-y-6">
      <!-- Name & Slug -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-300 mb-2">
            站名 <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="input-base w-full"
            placeholder="例如：OpenAI Hub"
          />
        </div>
        <div>
          <label for="slug" class="block text-sm font-medium text-slate-300 mb-2">
            Slug <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="slug"
            name="slug"
            required
            class="input-base w-full font-mono"
            placeholder="例如：openai-hub"
          />
        </div>
      </div>

      <!-- URL & Doc URL -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="url" class="block text-sm font-medium text-slate-300 mb-2">
            官网 URL <span class="text-red-400">*</span>
          </label>
          <input
            type="url"
            id="url"
            name="url"
            required
            class="input-base w-full"
            placeholder="https://example.com"
          />
        </div>
        <div>
          <label for="docUrl" class="block text-sm font-medium text-slate-300 mb-2">
            文档 URL
          </label>
          <input
            type="url"
            id="docUrl"
            name="docUrl"
            class="input-base w-full"
            placeholder="https://docs.example.com"
          />
        </div>
      </div>

      <!-- Description -->
      <div>
        <label for="description" class="block text-sm font-medium text-slate-300 mb-2">
          简介 <span class="text-red-400">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          required
          rows="3"
          class="input-base w-full resize-none"
          placeholder="中转站的简要描述..."
        ></textarea>
      </div>

      <!-- Models & Features -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="models" class="block text-sm font-medium text-slate-300 mb-2">
            支持模型 <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="models"
            name="models"
            required
            class="input-base w-full"
            placeholder="逗号分隔，例如：gpt-4o, claude-3.5-sonnet"
          />
          <p class="text-xs text-slate-500 mt-1">多个模型用英文逗号分隔</p>
        </div>
        <div>
          <label for="features" class="block text-sm font-medium text-slate-300 mb-2">
            特性
          </label>
          <input
            type="text"
            id="features"
            name="features"
            class="input-base w-full"
            placeholder="逗号分隔，例如：流式输出, 国内直连"
          />
          <p class="text-xs text-slate-500 mt-1">多个特性用英文逗号分隔</p>
        </div>
      </div>

      <!-- Rating & Payment Methods -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rating" class="block text-sm font-medium text-slate-300 mb-2">
            评分 <span class="text-red-400">*</span>
          </label>
          <input
            type="number"
            id="rating"
            name="rating"
            required
            min="0"
            max="5"
            step="0.1"
            class="input-base w-full"
            placeholder="4.5"
          />
          <p class="text-xs text-slate-500 mt-1">0 ~ 5 之间</p>
        </div>
        <div>
          <label for="paymentMethods" class="block text-sm font-medium text-slate-300 mb-2">
            支付方式
          </label>
          <input
            type="text"
            id="paymentMethods"
            name="paymentMethods"
            class="input-base w-full"
            placeholder="逗号分隔，例如：支付宝, 微信, USDT"
          />
          <p class="text-xs text-slate-500 mt-1">多种方式用英文逗号分隔</p>
        </div>
      </div>

      <!-- Pricing Editor -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm font-medium text-slate-300">
            模型定价 <span class="text-red-400">*</span>
          </label>
          <div class="flex gap-2">
            <button type="button" id="sync-models-btn" class="text-xs px-3 py-1.5 rounded-lg bg-slate-700/50 text-slate-300 hover:bg-slate-700 border border-slate-600/50 transition-colors">
              从模型列表同步
            </button>
            <button type="button" id="add-pricing-btn" class="text-xs px-3 py-1.5 rounded-lg bg-blue-600/20 text-blue-300 hover:bg-blue-600/30 border border-blue-500/30 transition-colors">
              + 添加模型
            </button>
          </div>
        </div>

        <div id="pricing-editor" class="space-y-2 border border-[#1e293b] rounded-xl p-3 bg-[#0b1120]/50">
          <!-- rows inserted by JS -->
        </div>

        <p class="text-xs text-slate-500 mt-1">
          价格为 USD / 1M tokens。点击「从模型列表同步」可自动添加上方填写的模型行。
        </p>
        <textarea id="pricing" name="pricing" class="hidden"></textarea>
      </div>

      <!-- Error message -->
      <div
        id="error-msg"
        class="hidden text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"
      >
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-end gap-3 pt-2 border-t border-[#1e293b]">
        <a href="/admin" class="btn-ghost">取消</a>
        <button type="submit" id="submit-btn" class="btn-primary">
          <Save className="w-4 h-4" />
          创建中转站
        </button>
      </div>
    </form>
  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('station-form');
  const errorMsg = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');
  const pricingEditor = document.getElementById('pricing-editor');
  const pricingTextarea = document.getElementById('pricing');
  const addBtn = document.getElementById('add-pricing-btn');
  const syncBtn = document.getElementById('sync-models-btn');

  /* ---- Pricing Editor ---- */
  function createPricingRow(model = '', input = '', output = '') {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <input type="text" placeholder="模型名称" value="${model}"
        class="input-base flex-1 min-w-0 text-sm py-1.5 px-2" data-field="model" />
      <input type="number" placeholder="Input 价格" value="${input}" step="any"
        class="input-base w-28 text-sm py-1.5 px-2" data-field="input" />
      <input type="number" placeholder="Output 价格" value="${output}" step="any"
        class="input-base w-28 text-sm py-1.5 px-2" data-field="output" />
      <button type="button" class="shrink-0 p-1.5 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10 transition-colors" title="删除">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    `;
    row.querySelector('button').addEventListener('click', () => {
      row.remove();
      syncPricingJson();
    });
    row.querySelectorAll('input').forEach(inp =>
      inp.addEventListener('input', syncPricingJson)
    );
    return row;
  }

  function syncPricingJson() {
    const pricing = collectPricing();
    pricingTextarea.value = JSON.stringify(pricing);
    // Auto-sync models list
    const modelNames = Object.keys(pricing);
    if (modelNames.length > 0) {
      const currentModels = document.getElementById('models').value.trim();
      const existingSet = new Set(currentModels.split(',').map(s => s.trim()).filter(Boolean));
      modelNames.forEach(m => existingSet.add(m));
      document.getElementById('models').value = [...existingSet].join(', ');
    }
  }

  function collectPricing() {
    const pricing = {};
    pricingEditor.querySelectorAll('.flex.items-center').forEach(row => {
      const model = row.querySelector('[data-field="model"]').value.trim();
      const input = parseFloat(row.querySelector('[data-field="input"]').value);
      const output = parseFloat(row.querySelector('[data-field="output"]').value);
      if (model) {
        pricing[model] = {
          input: isNaN(input) ? 0 : input,
          output: isNaN(output) ? 0 : output,
          unit: 'per 1M tokens'
        };
      }
    });
    return pricing;
  }

  addBtn.addEventListener('click', () => {
    pricingEditor.appendChild(createPricingRow());
    pricingEditor.querySelector('.flex.items-center:last-child input').focus();
  });

  syncBtn.addEventListener('click', () => {
    const modelsStr = document.getElementById('models').value;
    const models = modelsStr.split(',').map(s => s.trim()).filter(Boolean);
    const existing = collectPricing();
    let added = 0;
    models.forEach(m => {
      if (!existing[m]) {
        pricingEditor.appendChild(createPricingRow(m));
        added++;
      }
    });
    if (added === 0 && models.length === 0) {
      alert('请先在上方「支持模型」中填写模型名称');
    }
    syncPricingJson();
  });

  /* ---- Form Submit ---- */
  function parseCommaList(value) {
    return value.split(',').map(s => s.trim()).filter(Boolean);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    const pricing = collectPricing();
    if (Object.keys(pricing).length === 0) {
      errorMsg.textContent = '请至少添加一个模型的定价';
      errorMsg.classList.remove('hidden');
      return;
    }

    const payload = {
      name: document.getElementById('name').value.trim(),
      slug: document.getElementById('slug').value.trim(),
      url: document.getElementById('url').value.trim(),
      description: document.getElementById('description').value.trim(),
      models: parseCommaList(document.getElementById('models').value),
      features: parseCommaList(document.getElementById('features').value),
      rating: parseFloat(document.getElementById('rating').value),
      paymentMethods: parseCommaList(document.getElementById('paymentMethods').value),
      docUrl: document.getElementById('docUrl').value.trim() || undefined,
      pricing: pricing,
    };

    submitBtn.disabled = true;
    const originalContent = submitBtn.innerHTML;
    submitBtn.innerHTML = '创建中...';

    try {
      const res = await fetch('/api/admin/stations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const data = await res.json().catch(() => ({}));
        errorMsg.textContent = data.error || '创建失败，请检查输入';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.textContent = '网络错误，请稍后重试';
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalContent;
    }
  });
</script>
