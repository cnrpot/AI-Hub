---
import Layout from '../../../../layouts/Layout.astro';
import { getStationBySlug } from '../../../../server/db';
import { ArrowLeft, Save, Trash2 } from 'lucide-react';

const { slug } = Astro.params;
const station = getStationBySlug(slug!);

if (!station) {
  return Astro.redirect('/404');
}

const pricingJson = JSON.stringify(station.pricing, null, 2);
const modelsStr = station.models.join(', ');
const featuresStr = station.features.join(', ');
const paymentStr = station.paymentMethods.join(', ');
---

<Layout title={`编辑 ${station.name} — AI Hub`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
      <a href="/admin" class="hover:text-slate-300 transition-colors">管理面板</a>
      <span>/</span>
      <span class="text-slate-300">{station.name}</span>
    </nav>

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-slate-100">编辑中转站</h1>
      <a href="/admin" class="btn-ghost">
        <ArrowLeft className="w-4 h-4" />
        返回
      </a>
    </div>

    <!-- Form -->
    <form id="station-form" data-slug={station.slug} class="card-base space-y-6">
      <!-- Name & Slug -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-300 mb-2">
            站名 <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            value={station.name}
            class="input-base w-full"
          />
        </div>
        <div>
          <label for="slug" class="block text-sm font-medium text-slate-300 mb-2">
            Slug <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="slug"
            name="slug"
            required
            value={station.slug}
            class="input-base w-full font-mono"
          />
        </div>
      </div>

      <!-- URL & Doc URL -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="url" class="block text-sm font-medium text-slate-300 mb-2">
            官网 URL <span class="text-red-400">*</span>
          </label>
          <input
            type="url"
            id="url"
            name="url"
            required
            value={station.url}
            class="input-base w-full"
          />
        </div>
        <div>
          <label for="docUrl" class="block text-sm font-medium text-slate-300 mb-2">
            文档 URL
          </label>
          <input
            type="url"
            id="docUrl"
            name="docUrl"
            value={station.docUrl || ''}
            class="input-base w-full"
          />
        </div>
      </div>

      <!-- Description -->
      <div>
        <label for="description" class="block text-sm font-medium text-slate-300 mb-2">
          简介 <span class="text-red-400">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          required
          rows="3"
          class="input-base w-full resize-none"
        >{station.description}</textarea>
      </div>

      <!-- Models & Features -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="models" class="block text-sm font-medium text-slate-300 mb-2">
            支持模型 <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="models"
            name="models"
            required
            value={modelsStr}
            class="input-base w-full"
          />
          <p class="text-xs text-slate-500 mt-1">多个模型用英文逗号分隔</p>
        </div>
        <div>
          <label for="features" class="block text-sm font-medium text-slate-300 mb-2">
            特性
          </label>
          <input
            type="text"
            id="features"
            name="features"
            value={featuresStr}
            class="input-base w-full"
          />
          <p class="text-xs text-slate-500 mt-1">多个特性用英文逗号分隔</p>
        </div>
      </div>

      <!-- Rating & Payment Methods -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rating" class="block text-sm font-medium text-slate-300 mb-2">
            评分 <span class="text-red-400">*</span>
          </label>
          <input
            type="number"
            id="rating"
            name="rating"
            required
            min="0"
            max="5"
            step="0.1"
            value={station.rating}
            class="input-base w-full"
          />
          <p class="text-xs text-slate-500 mt-1">0 ~ 5 之间</p>
        </div>
        <div>
          <label for="paymentMethods" class="block text-sm font-medium text-slate-300 mb-2">
            支付方式
          </label>
          <input
            type="text"
            id="paymentMethods"
            name="paymentMethods"
            value={paymentStr}
            class="input-base w-full"
          />
          <p class="text-xs text-slate-500 mt-1">多种方式用英文逗号分隔</p>
        </div>
      </div>

      <!-- Pricing JSON -->
      <div>
        <label for="pricing" class="block text-sm font-medium text-slate-300 mb-2">
          模型定价 (JSON) <span class="text-red-400">*</span>
        </label>
        <textarea
          id="pricing"
          name="pricing"
          required
          rows="8"
          class="input-base w-full font-mono text-xs resize-none"
        >{pricingJson}</textarea>
        <p class="text-xs text-slate-500 mt-1">
          JSON 格式，key 为模型名，value 包含 input / output / unit
        </p>
      </div>

      <!-- Error message -->
      <div
        id="error-msg"
        class="hidden text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"
      >
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-2 border-t border-[#1e293b]">
        <button type="button" id="delete-btn" class="inline-flex items-center gap-2 text-sm text-red-400 hover:text-red-300 transition-colors px-3 py-2 rounded-lg border border-red-500/30 hover:border-red-500/50">
          <Trash2 className="w-4 h-4" />
          删除此中转站
        </button>
        <div class="flex items-center gap-3">
          <a href="/admin" class="btn-ghost">取消</a>
          <button type="submit" id="submit-btn" class="btn-primary">
            <Save className="w-4 h-4" />
            保存修改
          </button>
        </div>
      </div>
    </form>
  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('station-form');
  const errorMsg = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');
  const deleteBtn = document.getElementById('delete-btn');
  const slug = form.getAttribute('data-slug');

  function parseCommaList(value) {
    return value
      .split(',')
      .map((s) => s.trim())
      .filter(Boolean);
  }

  // Submit (update)
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    // Parse pricing JSON
    let pricing;
    try {
      pricing = JSON.parse(document.getElementById('pricing').value);
    } catch (err) {
      errorMsg.textContent = '模型定价 JSON 格式错误，请检查';
      errorMsg.classList.remove('hidden');
      return;
    }

    const payload = {
      name: document.getElementById('name').value.trim(),
      slug: document.getElementById('slug').value.trim(),
      url: document.getElementById('url').value.trim(),
      description: document.getElementById('description').value.trim(),
      models: parseCommaList(document.getElementById('models').value),
      features: parseCommaList(document.getElementById('features').value),
      rating: parseFloat(document.getElementById('rating').value),
      paymentMethods: parseCommaList(document.getElementById('paymentMethods').value),
      docUrl: document.getElementById('docUrl').value.trim() || undefined,
      pricing: pricing,
    };

    submitBtn.disabled = true;
    const originalContent = submitBtn.innerHTML;
    submitBtn.innerHTML = '保存中...';

    try {
      const res = await fetch('/api/admin/stations/' + slug, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const data = await res.json().catch(() => ({}));
        errorMsg.textContent = data.error || '保存失败，请检查输入';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.textContent = '网络错误，请稍后重试';
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalContent;
    }
  });

  // Delete
  deleteBtn.addEventListener('click', async () => {
    if (!confirm('确认删除此中转站？此操作不可撤销。')) return;

    deleteBtn.disabled = true;
    const originalContent = deleteBtn.innerHTML;
    deleteBtn.innerHTML = '删除中...';

    try {
      const res = await fetch('/api/admin/stations/' + slug, { method: 'DELETE' });
      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const data = await res.json().catch(() => ({}));
        errorMsg.textContent = data.error || '删除失败';
        errorMsg.classList.remove('hidden');
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = originalContent;
      }
    } catch (err) {
      errorMsg.textContent = '网络错误，请稍后重试';
      errorMsg.classList.remove('hidden');
      deleteBtn.disabled = false;
      deleteBtn.innerHTML = originalContent;
    }
  });
</script>
