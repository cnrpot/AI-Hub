---
import Layout from '../../../layouts/Layout.astro';
import { getCardShopById } from '../../../server/db';
import { ArrowLeft, Save, Trash2 } from 'lucide-react';

const { id } = Astro.params;
const shop = getCardShopById(id!);

if (!shop) {
  return Astro.redirect('/admin');
}

const platformsStr = shop.platforms.join(', ');
const shopDataJson = JSON.stringify(shop);
---

<Layout title={`编辑 ${shop.name} — AI Hub`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
      <a href="/admin" class="hover:text-slate-300 transition-colors">管理面板</a>
      <span>/</span>
      <span class="text-slate-300">{shop.name}</span>
    </nav>

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-slate-100">编辑卡网</h1>
      <a href="/admin" class="btn-ghost">
        <ArrowLeft className="w-4 h-4" />
        返回
      </a>
    </div>

    <form id="shop-form" data-id={shop.id} class="card-base space-y-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-300 mb-2">店名 <span class="text-red-400">*</span></label>
          <input type="text" id="name" name="name" required value={shop.name} class="input-base w-full" />
        </div>
        <div>
          <label for="url" class="block text-sm font-medium text-slate-300 mb-2">网址 <span class="text-red-400">*</span></label>
          <input type="url" id="url" name="url" required value={shop.url} class="input-base w-full" />
        </div>
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-slate-300 mb-2">简介</label>
        <textarea id="description" name="description" rows="2" class="input-base w-full resize-none">{shop.description}</textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="shopType" class="block text-sm font-medium text-slate-300 mb-2">类型</label>
          <select id="shopType" name="shopType" class="input-base w-full">
            <option value="kami" selected={shop.shopType === 'kami'}>卡密自动发货</option>
            <option value="dujiao" selected={shop.shopType === 'dujiao'}>独角数卡</option>
            <option value="shopApi" selected={shop.shopType === 'shopApi'}>链动小铺</option>
            <option value="genericHtml" selected={shop.shopType === 'genericHtml'}>通用商城</option>
            <option value="other" selected={shop.shopType === 'other'}>其他</option>
          </select>
        </div>
        <div>
          <label for="platforms" class="block text-sm font-medium text-slate-300 mb-2">平台</label>
          <input type="text" id="platforms" name="platforms" value={platformsStr} class="input-base w-full" />
          <p class="text-xs text-slate-500 mt-1">多个平台用英文逗号分隔</p>
        </div>
      </div>

      <div>
        <label for="healthStatus" class="block text-sm font-medium text-slate-300 mb-2">健康状态</label>
        <select id="healthStatus" name="healthStatus" class="input-base w-full">
          <option value="healthy" selected={shop.healthStatus === 'healthy'}>正常</option>
          <option value="retrying" selected={shop.healthStatus === 'retrying'}>重试中</option>
          <option value="failing" selected={shop.healthStatus === 'failing'}>故障</option>
          <option value="unknown" selected={shop.healthStatus === 'unknown'}>未知</option>
        </select>
      </div>

      <!-- Product Editor -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm font-medium text-slate-300">商品列表</label>
          <button type="button" id="add-product-btn" class="text-xs px-3 py-1.5 rounded-lg bg-blue-600/20 text-blue-300 hover:bg-blue-600/30 border border-blue-500/30 transition-colors">
            + 添加商品
          </button>
        </div>

        <div id="product-editor" class="space-y-2 border border-[#1e293b] rounded-xl p-3 bg-[#0b1120]/50">
          <!-- rows inserted by JS -->
        </div>
        <p class="text-xs text-slate-500 mt-1">每行一个商品，价格单位为人民币（元）。</p>
        <script id="initial-shop-data" type="application/json" set:html={shopDataJson}></script>
      </div>

      <div id="error-msg" class="hidden text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>

      <div class="flex items-center justify-between pt-2 border-t border-[#1e293b]">
        <button type="button" id="delete-btn" class="inline-flex items-center gap-2 text-sm text-red-400 hover:text-red-300 transition-colors px-3 py-2 rounded-lg border border-red-500/30 hover:border-red-500/50">
          <Trash2 className="w-4 h-4" />
          删除此卡网
        </button>
        <div class="flex items-center gap-3">
          <a href="/admin" class="btn-ghost">取消</a>
          <button type="submit" id="submit-btn" class="btn-primary">
            <Save className="w-4 h-4" />
            保存修改
          </button>
        </div>
      </div>
    </form>
  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('shop-form');
  const errorMsg = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');
  const deleteBtn = document.getElementById('delete-btn');
  const shopId = form.getAttribute('data-id');
  const productEditor = document.getElementById('product-editor');
  const addBtn = document.getElementById('add-product-btn');

  const STOCK_OPTIONS = [
    { value: 'in_stock', label: '有货' },
    { value: 'low_stock', label: '库存不足' },
    { value: 'out_of_stock', label: '缺货' },
  ];

  function createProductRow(data = {}) {
    const row = document.createElement('div');
    row.className = 'grid grid-cols-12 gap-2 items-center';
    row.innerHTML = `
      <input type="text" placeholder="商品名称" value="${data.name || ''}"
        class="input-base col-span-3 text-sm py-1.5 px-2 min-w-0" data-field="name" />
      <input type="text" placeholder="平台" value="${data.platform || ''}"
        class="input-base col-span-2 text-sm py-1.5 px-2 min-w-0" data-field="platform" />
      <input type="text" placeholder="类型" value="${data.productType || ''}"
        class="input-base col-span-1 text-sm py-1.5 px-2 min-w-0" data-field="productType" />
      <input type="number" placeholder="价格" value="${data.price ?? ''}" step="any"
        class="input-base col-span-1 text-sm py-1.5 px-2 min-w-0" data-field="price" />
      <select class="input-base col-span-2 text-sm py-1.5 px-2" data-field="stockStatus">
        ${STOCK_OPTIONS.map(o => `<option value="${o.value}" ${data.stockStatus === o.value ? 'selected' : ''}>${o.label}</option>`).join('')}
      </select>
      <input type="text" placeholder="购买链接" value="${data.url || ''}"
        class="input-base col-span-2 text-sm py-1.5 px-2 min-w-0" data-field="url" />
      <button type="button" class="shrink-0 p-1.5 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10 transition-colors" title="删除">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    `;
    row.querySelector('button').addEventListener('click', () => row.remove());
    return row;
  }

  addBtn.addEventListener('click', () => {
    productEditor.appendChild(createProductRow());
    productEditor.lastElementChild.querySelector('input').focus();
  });

  // Load existing products
  try {
    const initialData = JSON.parse(document.getElementById('initial-shop-data').textContent);
    if (initialData.products && initialData.products.length > 0) {
      initialData.products.forEach(p => productEditor.appendChild(createProductRow(p)));
    }
  } catch (e) { /* no products */ }

  function collectProducts() {
    const products = [];
    productEditor.querySelectorAll('.grid.grid-cols-12').forEach(row => {
      const name = row.querySelector('[data-field="name"]').value.trim();
      if (!name) return;
      products.push({
        name,
        platform: row.querySelector('[data-field="platform"]').value.trim(),
        productType: row.querySelector('[data-field="productType"]').value.trim(),
        price: parseFloat(row.querySelector('[data-field="price"]').value) || 0,
        stockStatus: row.querySelector('[data-field="stockStatus"]').value,
        url: row.querySelector('[data-field="url"]').value.trim(),
        warranty: '',
      });
    });
    return products;
  }

  function parseCommaList(value) {
    return value.split(',').map(s => s.trim()).filter(Boolean);
  }

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    const payload = {
      name: document.getElementById('name').value.trim(),
      url: document.getElementById('url').value.trim(),
      description: document.getElementById('description').value.trim(),
      shopType: document.getElementById('shopType').value,
      platforms: parseCommaList(document.getElementById('platforms').value),
      healthStatus: document.getElementById('healthStatus').value,
      products: collectProducts(),
    };

    submitBtn.disabled = true;
    const originalContent = submitBtn.innerHTML;
    submitBtn.innerHTML = '保存中...';

    try {
      const res = await fetch('/api/admin/cardshops/' + shopId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const data = await res.json().catch(() => ({}));
        errorMsg.textContent = data.message || '保存失败';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.textContent = '网络错误';
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalContent;
    }
  });

  // Delete
  deleteBtn.addEventListener('click', async () => {
    if (!confirm('确认删除此卡网？此操作不可撤销。')) return;

    deleteBtn.disabled = true;
    deleteBtn.innerHTML = '删除中...';

    try {
      const res = await fetch('/api/admin/cardshops/' + shopId, { method: 'DELETE' });
      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const data = await res.json().catch(() => ({}));
        errorMsg.textContent = data.message || '删除失败';
        errorMsg.classList.remove('hidden');
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = '删除此卡网';
      }
    } catch (err) {
      errorMsg.textContent = '网络错误';
      errorMsg.classList.remove('hidden');
      deleteBtn.disabled = false;
      deleteBtn.innerHTML = '删除此卡网';
    }
  });
</script>
